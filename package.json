{
  "name": "badmixton-flow",
  "private": true,
  "scripts": {
    "start": "python3 -m http.server 8080",
    "test": "node --test test/*.test.js",
    "check": "node --check assets/js/app.js && node --check assets/js/i18n.js",
    "validate": "npm run check && npm test && npm run simulation:validate && npm run lighthouse",
    "simulation": "node scripts/simulation.js",
    "simulation:shuffle": "node scripts/simulation-shuffle.js",
    "simulation:validate": "node scripts/simulation-validate.js",
    "screenshots": "node scripts/screenshots.js",
    "screenshot:print": "node scripts/screenshot-print.js",
    "lighthouse": "node scripts/lighthouse.js"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "playwright": "^1.58.2"
  },
  "overrides": {
    "tmp": "0.2.4",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "basic-ftp": "^5.3.0"
  }
}
